# === TheWorkshop Backend Environment Variables ===
# Copy this file to .env and fill in your values

# JWT Secret Key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Database URL — PostgreSQL connection string
# For Supabase: postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./database.db

# Comma-separated list of allowed frontend origins
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# Google Gemini API Key for AI Tutor & Flashcards
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Admin email — this user will be auto-promoted to admin on startup
ADMIN_EMAIL=admin@example.com
